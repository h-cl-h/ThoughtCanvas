<Window x:Class="BmapUiEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="BMAP 界面编辑器 V0.0.3" Height="780" Width="1380"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei" FontSize="13" Background="#f5f6f8">

    <Window.Resources>
        <Style TargetType="Button" x:Key="Tool">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="ToolV">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="Mini">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Margin" Value="0,10,0,3"/>
            <Setter Property="Foreground" Value="#5b6070"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
    <!-- ================= 编辑器 ================= -->
    <DockPanel x:Name="EditorRoot" Visibility="Collapsed">
        <!-- 顶部工具条 -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#e2e5ec" BorderThickness="0,0,0,1" Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BtnHome" Style="{StaticResource Tool}" Content="🏠 开始页"/>
                    <Border Width="1" Background="#e2e5ec" Margin="4,2,10,2"/>
                    <Button x:Name="BtnNew"    Style="{StaticResource Tool}" Content="✚ 新建"/>
                    <Button x:Name="BtnOpen"   Style="{StaticResource Tool}" Content="📂 打开…"/>
                    <Button x:Name="BtnSave"   Style="{StaticResource Tool}" Content="💾 保存 .bmapui"/>
                    <Button x:Name="BtnSaveAs" Style="{StaticResource Tool}" Content="另存为…"/>
                    <Border Width="1" Background="#e2e5ec" Margin="4,2,10,2"/>
                    <Button x:Name="BtnUndo"   Style="{StaticResource Tool}" Content="↩ 撤销"/>
                    <Button x:Name="BtnRedo"   Style="{StaticResource Tool}" Content="↪ 重做"/>
                    <Border Width="1" Background="#e2e5ec" Margin="4,2,10,2"/>
                    <Button x:Name="BtnPrefs"  Style="{StaticResource Tool}" Content="⚙ 偏好"/>
                    <TextBlock x:Name="TxtCurrent" VerticalAlignment="Center" Margin="14,0,0,0"
                               Foreground="#8a90a0" Text="未命名"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <RadioButton x:Name="RbViewCanvas" Content="🎨 画布" IsChecked="True" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <RadioButton x:Name="RbViewPreview" Content="👁 真实预览（可打字试拉伸）" VerticalAlignment="Center" Margin="0,0,6,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 底部状态条 -->
        <Border DockPanel.Dock="Bottom" Background="#eef1f6" Padding="12,5">
            <TextBlock x:Name="TxtStatus" Foreground="#5b6070" Text="就绪"/>
        </Border>

        <!-- 左：选部件来设计 + 绘图工具 -->
        <Border DockPanel.Dock="Left" Width="222" Background="White" BorderBrush="#e2e5ec" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <TextBlock Text="① 选部件来设计（可展开分类）" FontWeight="Bold" Margin="0,2,0,4"/>
                    <TreeView x:Name="DesignTree" Height="232" BorderBrush="#e2e5ec"/>
                    <TextBlock x:Name="DesignHint" TextWrapping="Wrap" Foreground="#185FA5" FontSize="11.5" Margin="0,5,0,0"
                               Text="正在设计：普通节点 / 文本框"/>

                    <TextBlock Text="② 画它的样子" FontWeight="Bold" Margin="0,16,0,2"/>
                    <TextBlock Text="在设计框里画（可超出框，导出只取框内）" TextWrapping="Wrap" Foreground="#8a90a0" FontSize="11.5" Margin="0,0,0,2"/>
                    <Button x:Name="BtnAddRect"    Style="{StaticResource ToolV}" Content="▭  矩形"/>
                    <Button x:Name="BtnAddRound"   Style="{StaticResource ToolV}" Content="▢  圆角矩形"/>
                    <Button x:Name="BtnAddEllipse" Style="{StaticResource ToolV}" Content="◯  圆形"/>
                    <Button x:Name="BtnAddLine"    Style="{StaticResource ToolV}" Content="╱  直线"/>
                    <Button x:Name="BtnAddText"    Style="{StaticResource ToolV}" Content="🅣  文本区（文字放这儿）"/>
                    <ToggleButton x:Name="BtnPen" Height="30" Margin="0,5,0,0" Padding="10,0"
                                  HorizontalContentAlignment="Left" Cursor="Hand" Content="🖊  画笔（手绘）"/>
                    <Button x:Name="BtnAddImage" Style="{StaticResource ToolV}" Content="🖼  导入图片 (JPG/PNG)"/>

                    <StackPanel x:Name="PanelPen" Visibility="Collapsed" Margin="0,8,0,0">
                        <TextBlock Text="画笔颜色" Foreground="#5b6070" Margin="0,4,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="SwPen" Width="24" Height="24" CornerRadius="5" BorderBrush="#ccc" BorderThickness="1" Margin="0,0,6,0"/>
                            <TextBox x:Name="TxtPen" Width="88" Text="#5b8def"/>
                            <Button x:Name="BtnPenPick" Style="{StaticResource Mini}" Content="取色" Margin="5,0,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="LblPenW" Text="画笔粗细：3" Foreground="#5b6070" Margin="0,8,0,3"/>
                        <Slider x:Name="SldPenW" Minimum="1" Maximum="16" Value="3" TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="松手一笔＝一个图层。再点一次「画笔」退出。"
                                   TextWrapping="Wrap" Foreground="#8a90a0" FontSize="11.5" Margin="0,6,0,0"/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Foreground="#8a90a0" FontSize="11.5" Margin="0,14,0,0"
                               Text="拖动＝移动 · 拖小方块＝缩放&#10;可用图层/遮罩做 PS 式裁剪&#10;Ctrl+Z 撤销 · Ctrl+Y 重做&#10;Delete 删除 · 方向键微调&#10;没设计的部件＝保持原版&#10;（限定框/自由、固定文字在 ⚙偏好·高级模式）"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 中 + 右：画布 | 分隔条 | 属性（宽度可拖） -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="250" MaxWidth="600"/>
            </Grid.ColumnDefinitions>

            <!-- 画布 / 真实预览 -->
            <Grid Grid.Column="0">
                <Border x:Name="CanvasView" Background="#e9ebef" Padding="20">
                    <Viewbox Stretch="Uniform">
                        <Border Background="White" BorderBrush="#c9cdd6" BorderThickness="1">
                            <Grid Width="1200" Height="700" ClipToBounds="True">
                                <TextBlock x:Name="TxtEmptyHint" Text="空画布 —— 直接画图形 / 手绘 / 导入图片；淡淡的原版界面是参考底图，点它可加进来改（浓度在 ⚙偏好 里调）"
                                           Foreground="#b8bdc9" FontSize="15" TextWrapping="Wrap" MaxWidth="600" TextAlignment="Center"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Canvas x:Name="GhostHost" Width="1200" Height="700" Background="Transparent"/>
                                <Canvas x:Name="Stage" Width="1200" Height="700" Background="{x:Null}"/>
                                <InkCanvas x:Name="Pen" Width="1200" Height="700" Background="Transparent" Visibility="Collapsed"/>
                                <Canvas x:Name="DrawLayer" Width="1200" Height="700" Background="Transparent" Visibility="Collapsed" Cursor="Cross"/>
                                <Canvas x:Name="Overlay" Width="1200" Height="700"/>
                            </Grid>
                        </Border>
                    </Viewbox>
                </Border>
                <Grid x:Name="WebHost" Visibility="Collapsed" Background="White">
                    <wv2:WebView2 x:Name="Web"/>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#e2e5ec"/>

            <!-- 右：图层（自动撑满）+ 可拖分隔 + 属性 -->
            <Border Grid.Column="2" Background="White" BorderBrush="#e2e5ec" BorderThickness="1,0,0,0">
                <Grid Margin="12,8,12,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="110"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="1.4*" MinHeight="170"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource Label}" Text="方案名（导入软件后显示）" Margin="0,2,0,3"/>
                        <TextBox x:Name="TxtName" Text="自定义界面"/>
                        <TextBlock Style="{StaticResource Label}" Text="图层（上面的盖住下面的 · 拖下方横条可调高度）"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button x:Name="BtnLayerUp"     Style="{StaticResource Mini}" Content="⬆ 上移"/>
                            <Button x:Name="BtnLayerDown"   Style="{StaticResource Mini}" Content="⬇ 下移"/>
                            <Button x:Name="BtnLayerTop"    Style="{StaticResource Mini}" Content="置顶"/>
                            <Button x:Name="BtnLayerBottom" Style="{StaticResource Mini}" Content="置底"/>
                            <Button x:Name="BtnLayerDel"    Style="{StaticResource Mini}" Content="🗑"/>
                        </StackPanel>
                    </StackPanel>

                    <ListBox x:Name="LayerList" Grid.Row="1" BorderBrush="#e2e5ec"/>

                    <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#e2e5ec" Margin="0,2"/>

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- 部件调色 -->
                            <StackPanel x:Name="PanelComp" Visibility="Collapsed">
                                <TextBlock x:Name="CompTitle" FontWeight="Bold" Margin="0,6,0,0" Foreground="#23262e"/>
                                <StackPanel x:Name="PanelCompProps"/>
                            </StackPanel>

                            <!-- 图形调色 -->
                            <StackPanel x:Name="PanelShape" Visibility="Collapsed">
                                <TextBlock x:Name="ShapeTitle" FontWeight="Bold" Margin="0,6,0,0" Foreground="#23262e"/>

                                <StackPanel x:Name="RowSize">
                                    <TextBlock Style="{StaticResource Label}" Text="尺寸 / 位置（相对设计框，100%=整宽/整高）"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="宽" VerticalAlignment="Center" Foreground="#5b6070"/>
                                        <TextBox x:Name="TxtSizeW" Width="52" Margin="4,0,2,0"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Foreground="#8a90a0" Margin="0,0,10,0"/>
                                        <TextBlock Text="高" VerticalAlignment="Center" Foreground="#5b6070"/>
                                        <TextBox x:Name="TxtSizeH" Width="52" Margin="4,0,2,0"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Foreground="#8a90a0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="X" VerticalAlignment="Center" Foreground="#5b6070"/>
                                        <TextBox x:Name="TxtSizeX" Width="52" Margin="4,0,2,0"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Foreground="#8a90a0" Margin="0,0,10,0"/>
                                        <TextBlock Text="Y" VerticalAlignment="Center" Foreground="#5b6070"/>
                                        <TextBox x:Name="TxtSizeY" Width="52" Margin="4,0,2,0"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Foreground="#8a90a0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkSquare" Content="锁定 1:1（正方形 / 正圆）" Margin="0,6,0,0"/>
                                </StackPanel>

                                <StackPanel x:Name="RowFill">
                                    <TextBlock Style="{StaticResource Label}" Text="填充色"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="SwFill" Width="26" Height="26" CornerRadius="5" BorderBrush="#ccc" BorderThickness="1" Margin="0,0,6,0"/>
                                        <TextBox x:Name="TxtFill" Width="96"/>
                                        <Button x:Name="BtnFillPick" Style="{StaticResource Tool}" Content="取色" Margin="6,0,0,0" Height="28"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkNoFill" Content="无填充（只留边框）" Margin="0,6,0,0"/>
                                </StackPanel>

                                <TextBlock Style="{StaticResource Label}" Text="边框 / 线条色"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="SwStroke" Width="26" Height="26" CornerRadius="5" BorderBrush="#ccc" BorderThickness="1" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtStroke" Width="96"/>
                                    <Button x:Name="BtnStrokePick" Style="{StaticResource Tool}" Content="取色" Margin="6,0,0,0" Height="28"/>
                                </StackPanel>

                                <TextBlock x:Name="LblStrokeW" Style="{StaticResource Label}" Text="边框粗细：0"/>
                                <Slider x:Name="SldStrokeW" Minimum="0" Maximum="12" TickFrequency="0.5" IsSnapToTickEnabled="True"/>

                                <StackPanel x:Name="RowRadius">
                                    <TextBlock x:Name="LblRadius" Style="{StaticResource Label}" Text="圆角：12"/>
                                    <Slider x:Name="SldRadius" Minimum="0" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                </StackPanel>

                                <TextBlock x:Name="LblOpacity" Style="{StaticResource Label}" Text="透明度：100%"/>
                                <Slider x:Name="SldOpacity" Minimum="10" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="BtnMaskShape" Style="{StaticResource Tool}" Content="🎭 加遮罩" Height="28"/>
                                    <Button x:Name="BtnDelShape" Style="{StaticResource Tool}" Content="🗑 删除" Height="28"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkMask" Content="把这个图形本身当遮罩（裁剪它下面那层）" Margin="0,10,0,0"/>
                            </StackPanel>

                            <!-- 手绘调色 -->
                            <StackPanel x:Name="PanelInk" Visibility="Collapsed">
                                <TextBlock x:Name="InkTitle" FontWeight="Bold" Margin="0,6,0,0" Foreground="#23262e" Text="手绘笔迹"/>
                                <TextBlock Style="{StaticResource Label}" Text="颜色"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="SwInk" Width="26" Height="26" CornerRadius="5" BorderBrush="#ccc" BorderThickness="1" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtInk" Width="96"/>
                                    <Button x:Name="BtnInkPick" Style="{StaticResource Tool}" Content="取色" Margin="6,0,0,0" Height="28"/>
                                </StackPanel>
                                <TextBlock x:Name="LblInkW" Style="{StaticResource Label}" Text="粗细：3"/>
                                <Slider x:Name="SldInkW" Minimum="1" Maximum="16" TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                                <TextBlock x:Name="LblInkOpacity" Style="{StaticResource Label}" Text="透明度：100%"/>
                                <Slider x:Name="SldInkOpacity" Minimum="10" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="BtnMaskInk" Style="{StaticResource Tool}" Content="🎭 加遮罩" Height="28"/>
                                    <Button x:Name="BtnDelInk" Style="{StaticResource Tool}" Content="🗑 删除" Height="28"/>
                                </StackPanel>
                                <TextBlock Text="手绘可整体拖动，暂不支持缩放。" TextWrapping="Wrap" Foreground="#8a90a0" FontSize="11.5" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- 图片属性 -->
                            <StackPanel x:Name="PanelImage" Visibility="Collapsed">
                                <TextBlock x:Name="ImgTitle" FontWeight="Bold" Margin="0,6,0,0" Foreground="#23262e" Text="图片"/>
                                <TextBlock x:Name="LblImgOpacity" Style="{StaticResource Label}" Text="透明度：100%"/>
                                <Slider x:Name="SldImgOpacity" Minimum="10" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="BtnMaskImg" Style="{StaticResource Tool}" Content="🎭 加遮罩" Height="28"/>
                                    <Button x:Name="BtnDelImg" Style="{StaticResource Tool}" Content="🗑 删除" Height="28"/>
                                </StackPanel>
                                <TextBlock Text="点「🎭 加遮罩」把图片裁成圆角/圆形——遮罩盖上后拖动它、缩放它就懂了。"
                                           TextWrapping="Wrap" Foreground="#8a90a0" FontSize="11.5" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- 文本区属性 -->
                            <StackPanel x:Name="PanelText" Visibility="Collapsed">
                                <TextBlock FontWeight="Bold" Margin="0,6,0,0" Foreground="#23262e" Text="文本区（文字放这儿）"/>
                                <TextBlock Style="{StaticResource Label}" Text="示例文字（导出后=部件真正的字，可编辑）"/>
                                <TextBox x:Name="TxtRegionText" Height="52" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>
                                <TextBlock x:Name="LblTextSize" Style="{StaticResource Label}" Text="字号：14"/>
                                <Slider x:Name="SldTextSize" Minimum="8" Maximum="48" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                <TextBlock Style="{StaticResource Label}" Text="字色"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="SwText" Width="26" Height="26" CornerRadius="5" BorderBrush="#ccc" BorderThickness="1" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TxtTextColor" Width="96"/>
                                    <Button x:Name="BtnTextColorPick" Style="{StaticResource Tool}" Content="取色" Margin="6,0,0,0" Height="28"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource Label}" Text="对齐 / 加粗"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnAlignL" Style="{StaticResource Mini}" Content="左" Height="28" Width="34"/>
                                    <Button x:Name="BtnAlignC" Style="{StaticResource Mini}" Content="中" Height="28" Width="34"/>
                                    <Button x:Name="BtnAlignR" Style="{StaticResource Mini}" Content="右" Height="28" Width="34"/>
                                    <CheckBox x:Name="ChkTextBold" Content="加粗" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <StackPanel x:Name="RowTextSource" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource Label}" Text="内容来源（高级）"/>
                                    <ComboBox x:Name="CmbTextSource" Width="180" Height="28" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <Button x:Name="BtnDelText" Style="{StaticResource Tool}" Content="🗑 删除文本区" Height="28" Margin="0,12,0,0" HorizontalAlignment="Left"/>
                                <TextBlock Text="拖动/缩放这个虚线框＝文字在部件里的位置与留白。" TextWrapping="Wrap" Foreground="#8a90a0" FontSize="11.5" Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- 什么都没选时的提示 -->
                            <TextBlock x:Name="PanelTips" TextWrapping="Wrap" Foreground="#8a90a0" FontSize="12" Margin="0,6,0,0"
                                       Text="怎么用：&#10;&#10;① 左侧选一个部件（文本框/按钮…）。&#10;② 在设计框里画它的新样子（矩形/圆/线/画笔/图片，可用遮罩裁剪）。&#10;③ 放一个「🅣 文本区」，那儿就是部件真正的文字。&#10;④ 只有设计框内的会显示；没设计的部件保持原版。&#10;&#10;「👁 真实预览」里可直接打字看效果。Ctrl+Z 撤销。&#10;想自由不限框 / 固定文字 → ⚙偏好·高级模式。"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>

    <!-- ================= 开始页 ================= -->
    <Grid x:Name="HomeRoot" Background="#f5f6f8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="36,40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#12a087" Offset="0"/>
                    <GradientStop Color="#2f80ed" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="56" Height="56" CornerRadius="15" Background="#33ffffff">
                            <TextBlock Text="🖌" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BMAP 界面编辑器" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="UI CANVAS" Foreground="#d2f3e9" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,24,0,0" Foreground="#eafff8" FontSize="13" TextWrapping="Wrap"
                               Text="从零手搓 ThoughtCanvas 界面：图形 / 画笔 / 图片 / 图层 / 遮罩，没改的自动保持原版。保存的 .bmapui 直接导入软件。"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="V0.0.3" Foreground="#cfeee4" FontSize="12" VerticalAlignment="Bottom"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="52,42">
            <StackPanel>
                <TextBlock Text="开始" FontSize="15" FontWeight="SemiBold" Foreground="#3a4050" Margin="0,0,0,16"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="HomeNewBtn" Width="200" Cursor="Hand" Margin="0,0,18,0"
                            HorizontalContentAlignment="Left" BorderBrush="#e2e5ec" Background="White">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1" CornerRadius="14" Padding="18">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel>
                            <Border Height="88" CornerRadius="10" Margin="0,0,0,13">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#12a087" Offset="0"/>
                                        <GradientStop Color="#2fb59d" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="＋" FontSize="42" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="新建界面方案" FontSize="14.5" FontWeight="SemiBold" Foreground="#23262e"/>
                            <TextBlock Text="空画布，从零开始画" FontSize="12" Foreground="#8a90a0" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="HomeOpenBtn" Width="200" Cursor="Hand"
                            HorizontalContentAlignment="Left" BorderBrush="#e2e5ec" Background="White">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
