{
  "name": "brace-mindmap",
  "version": "0.0.5",
  "description": "ThoughtCanvas — 完全自定义、本地优先的思维导图工具",
  "author": "happymore",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.thoughtcanvas.app",
    "productName": "ThoughtCanvas",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "libs/**/*",
      "themes/**/*",
      "build/icon.ico"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico",
      "artifactName": "ThoughtCanvas.exe"
    },
    "portable": {
      "artifactName": "ThoughtCanvas.exe",
      "unpackDirName": "ThoughtCanvas",
      "splashImage": null
    },
    "compression": "normal"
  },
  "dependencies": {
    "jspdf": "^4.2.1"
  }
}
