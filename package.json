{
  "name": "knotjot",
  "version": "0.0.9",
  "description": "KnotJot (ThoughtCanvas V0.0.9) — a flexible, local-first desktop mind-mapping tool",
  "author": "happymore",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/h-cl-h/KnotJot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h-cl-h/KnotJot.git"
  },
  "bugs": {
    "url": "https://github.com/h-cl-h/KnotJot/issues"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test:performance": "electron tests/performance-smoke.js",
    "test:text-styles": "electron tests/text-styles-smoke.js",
    "test:text-input": "electron tests/live-input-rules-smoke.js",
    "test:user-style": "electron tests/user-style-centering-smoke.js",
    "test:node-textboxes": "electron tests/node-textbox-audit-smoke.js",
    "test:sizing-modes": "electron tests/two-sizing-modes-smoke.js",
    "test:wpf-style-parity": "electron tests/wpf-real-library-parity-smoke.js",
    "test:text-region-roundtrip": "electron tests/text-region-roundtrip-smoke.js",
    "test:visual-unified": "electron tests/unified-layer-visual-smoke.js",
    "test:real-style-sizing": "electron tests/real-style-sizing-regression.js",
    "test:appearance": "electron tests/appearance-background-smoke.js",
    "test:ui-hot-sync": "electron tests/ui-skins-hot-reload-smoke.js",
    "generate:stress-fixture": "node tests/generate-stress-fixture.js",
    "dist": "electron-builder --win",
    "dist:win": "electron-builder --win",
    "dist:win:installer": "electron-builder --win nsis",
    "dist:win:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.thoughtcanvas.app.v009",
    "productName": "ThoughtCanvas",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "appearance.css",
      "appearance.js",
      "text-styles.css",
      "text-styles.js",
      "text-styles/**/*",
      "libs/**/*",
      "themes/**/*",
      "build/icon.ico",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "THIRD_PARTY_LICENSES/**/*"
    ],
    "extraResources": [
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "THIRD_PARTY_LICENSES",
        "to": "THIRD_PARTY_LICENSES"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ThoughtCanvas"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}",
      "unpackDirName": "ThoughtCanvas",
      "splashImage": null
    },
    "fileAssociations": [
      {
        "ext": "bmap",
        "name": "ThoughtCanvas 思维导图",
        "description": "ThoughtCanvas 思维导图文件",
        "icon": "build/icon.ico",
        "role": "Editor"
      }
    ],
    "compression": "normal"
  },
  "dependencies": {
    "jspdf": "^4.2.1"
  }
}
