<Window x:Class="BmapTextStyleEditor.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="BMAP 文本框样式编辑器 V0.0.1" Icon="assets/icon.ico" Width="1450" Height="850" MinWidth="1080" MinHeight="680" WindowStartupLocation="CenterScreen" FontFamily="Microsoft YaHei" Background="#F4F6F9">
 <Window.Resources>
  <Style TargetType="Button"><Setter Property="Padding" Value="11,6"/><Setter Property="Margin" Value="0,0,6,0"/><Setter Property="Cursor" Value="Hand"/></Style>
  <Style TargetType="TextBox"><Setter Property="Padding" Value="6,4"/><Setter Property="Margin" Value="0,2,0,7"/></Style>
  <Style TargetType="ComboBox"><Setter Property="Padding" Value="5"/><Setter Property="Margin" Value="0,2,0,7"/></Style>
  <Style TargetType="TextBlock" x:Key="Label"><Setter Property="Foreground" Value="#596174"/><Setter Property="Margin" Value="0,6,0,0"/></Style>
 </Window.Resources>
 <Grid>
 <DockPanel x:Name="EditorRoot" Visibility="Collapsed">
  <Border DockPanel.Dock="Top" Background="White" BorderBrush="#DDE2EB" BorderThickness="0,0,0,1" Padding="12,9"><DockPanel>
   <StackPanel Orientation="Horizontal"><Button x:Name="HomeBtn" Content="开始页"/><Button x:Name="NewBtn" Content="新建"/><Button x:Name="OpenBtn" Content="打开样式"/><Button x:Name="SaveBtn" Content="保存独立文件"/><Button x:Name="UndoBtn" Content="撤销"/><Button x:Name="RedoBtn" Content="重做"/><Button x:Name="ConnectBtn" Content="连接主程序…" Background="#E8F0FF"/><Button x:Name="SyncBtn" Content="保存并同步" Background="#5B8DEF" Foreground="White"/><Button x:Name="LaunchBtn" Content="打开主程序"/><Button x:Name="FloatToolsBtn" Content="浮动工具"/><Button x:Name="LanguageBtn" Content="EN"/></StackPanel>
   <TextBlock x:Name="ConnectionText" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#697184" Text="未连接主程序（可独立使用）"/>
  </DockPanel></Border>
  <Border DockPanel.Dock="Bottom" Background="#EAF1FF" Padding="10,6"><TextBlock x:Name="StatusText" Foreground="#315EAE" Text="就绪"/></Border>
  <Grid>
   <Grid.ColumnDefinitions><ColumnDefinition Width="270"/><ColumnDefinition Width="*"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
   <Border Grid.Column="0" Background="White" BorderBrush="#DDE2EB" BorderThickness="0,0,1,0"><ScrollViewer><StackPanel Margin="12">
    <TextBlock Text="绘制工具" FontSize="15" FontWeight="Bold" Margin="0,2,0,8"/>
    <Button x:Name="SelectTool" Content="选择 / 移动" HorizontalContentAlignment="Left" Margin="0,3"/>
    <Button x:Name="RectTool" Content="矩形" HorizontalContentAlignment="Left" Margin="0,3"/>
    <Button x:Name="RoundTool" Content="圆角矩形" HorizontalContentAlignment="Left" Margin="0,3"/>
    <Button x:Name="EllipseTool" Content="椭圆" HorizontalContentAlignment="Left" Margin="0,3"/>
    <Button x:Name="LineTool" Content="直线" HorizontalContentAlignment="Left" Margin="0,3"/>
    <Button x:Name="ImportImageBtn" Content="导入图片…" HorizontalContentAlignment="Left" Margin="0,3"/>
    <Button x:Name="TextTool" Content="文本区域（重画会替换）" HorizontalContentAlignment="Left" Margin="0,3"/>
    <CheckBox x:Name="SquareSnapBox" Content="比例吸附：1:1 / 4:3 / 3:2 / 16:9" IsChecked="True" Margin="0,10,0,3"/>
    <CheckBox x:Name="ObjectSnapBox" Content="吸附其他图层的边缘和中心" IsChecked="True" Margin="0,3"/>
    <CheckBox x:Name="GridSnapBox" Content="网格吸附" IsChecked="True" Margin="0,3"/>
    <TextBlock Style="{StaticResource Label}" Text="网格大小（像素）"/><TextBox x:Name="GridSizeBox" Text="10"/>
    <TextBlock Style="{StaticResource Label}" Text="绘制长宽比（0=自由，例如 1、1.5、16/9）"/>
    <TextBox x:Name="DrawRatioBox" Text="0"/>
    <TextBlock TextWrapping="Wrap" Foreground="#7C8495" FontSize="12" Margin="0,14,0,0" Text="在中央设计框内拖动绘制。使用选择工具移动图形；右侧图层面板可拖动排序。"/>
   </StackPanel></ScrollViewer></Border>
   <TabControl Grid.Column="1" x:Name="WorkTabs" Margin="12">
    <TabItem Header="设计画布"><Border Background="#DDE1E8" Padding="24"><Viewbox Stretch="Uniform"><Border Background="White" BorderBrush="#AEB6C5" BorderThickness="1"><Canvas x:Name="DesignCanvas" Width="900" Height="520" Background="#FFFFFF" ClipToBounds="True"/></Border></Viewbox></Border></TabItem>
      <TabItem Header="独立预览"><ScrollViewer Background="#E8EBF0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"><Grid MinWidth="640" MinHeight="420"><Border x:Name="PreviewCard" Width="420" MinHeight="0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30" Margin="24"><Grid><Canvas x:Name="PreviewLayers" IsHitTestVisible="False"/><TextBox x:Name="PreviewText" Text="在这里输入文字，测试样式和拉伸效果" TextWrapping="Wrap" AcceptsReturn="True" Padding="6,4" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent"/></Grid></Border></Grid></ScrollViewer></TabItem>
   </TabControl>
   <Border Grid.Column="2" Background="White" BorderBrush="#DDE2EB" BorderThickness="1,0,0,0"><ScrollViewer><StackPanel Margin="14">
    <TextBlock Text="图层" FontSize="15" FontWeight="Bold"/>
    <ListBox x:Name="LayerList" Height="240" AllowDrop="True" SelectionMode="Extended" Margin="0,7">
     <ListBox.ItemTemplate><DataTemplate><Grid Margin="2"><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><CheckBox Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" Content="◉" ToolTip="显示/隐藏" Click="LayerVisibilityChanged"/><CheckBox Grid.Column="1" IsChecked="{Binding IsLocked, Mode=TwoWay}" Content="🔒" ToolTip="锁定" Click="LayerLockChanged"/><TextBlock Grid.Column="2" Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/></Grid></DataTemplate></ListBox.ItemTemplate>
    </ListBox>
    <WrapPanel><Button x:Name="UpBtn" Content="上移"/><Button x:Name="DownBtn" Content="下移"/><Button x:Name="TopBtn" Content="置顶"/><Button x:Name="BottomBtn" Content="置底"/><Button x:Name="DeleteBtn" Content="删除"/></WrapPanel>
    <Separator Margin="0,10"/>
    <TextBlock Text="样式属性" FontSize="15" FontWeight="Bold"/>
    <TextBlock Style="{StaticResource Label}" Text="样式名称"/><TextBox x:Name="NameBox" Text="我的文本框样式"/>
    <TextBlock Style="{StaticResource Label}" Text="样式 ID（英文/数字/短横线）"/><TextBox x:Name="IdBox" Text="my-text-style"/>
    <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Style="{StaticResource Label}" Text="底色"/><TextBox x:Name="BgBox" Text="#FFFFFF"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Style="{StaticResource Label}" Text="边框色"/><TextBox x:Name="BorderBox" Text="#5B8DEF"/></StackPanel></UniformGrid>
    <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Style="{StaticResource Label}" Text="文字色"/><TextBox x:Name="ColorBox" Text="#2C3140"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Style="{StaticResource Label}" Text="圆角"/><TextBox x:Name="RadiusBox" Text="12"/></StackPanel></UniformGrid>
    <TextBlock Style="{StaticResource Label}" Text="字体（读取 Windows 已安装字体）"/><ComboBox x:Name="FontBox" IsTextSearchEnabled="True" MaxDropDownHeight="320"/>
    <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Style="{StaticResource Label}" Text="字号"/><TextBox x:Name="FontSizeBox" Text="14"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Style="{StaticResource Label}" Text="尺寸策略"/><ComboBox x:Name="SizeModeBox"><ComboBoxItem Tag="uniform" Content="固定长宽比"/><ComboBoxItem Tag="stretch" Content="自由拉伸"/></ComboBox></StackPanel></UniformGrid>
    <TextBlock Style="{StaticResource Label}" Text="文本框长宽比（可手动输入，如 1、1.5、16/9）"/><TextBox x:Name="AspectBox" Text="1.8"/>
    <Separator Margin="0,8"/><TextBlock Text="输入限制" FontWeight="Bold"/>
    <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Style="{StaticResource Label}" Text="最多字符（0=不限）"/><TextBox x:Name="MaxLengthBox" Text="0"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Style="{StaticResource Label}" Text="允许类型"/><ComboBox x:Name="InputTypeBox"><ComboBoxItem Tag="any" Content="任意"/><ComboBoxItem Tag="number" Content="仅数字"/><ComboBoxItem Tag="letter" Content="仅字母"/><ComboBoxItem Tag="chinese" Content="仅中文"/><ComboBoxItem Tag="alnum" Content="数字和字母"/><ComboBoxItem Tag="regex" Content="自定义正则"/></ComboBox></StackPanel></UniformGrid>
    <TextBlock Style="{StaticResource Label}" Text="自定义正则"/><TextBox x:Name="PatternBox"/><CheckBox x:Name="RequiredBox" Content="不允许空值" Margin="0,2,0,8"/>
    <Separator Margin="0,8"/><TextBlock Text="选中图层" FontWeight="Bold"/>
    <UniformGrid Columns="2"><StackPanel Margin="0,0,6,0"><TextBlock Style="{StaticResource Label}" Text="填充（图形默认实心）"/><TextBox x:Name="LayerFillBox" Text="#DDE9FF"/></StackPanel><StackPanel Margin="6,0,0,0"><TextBlock Style="{StaticResource Label}" Text="描边（始终实线）"/><TextBox x:Name="LayerStrokeBox" Text="#5B8DEF"/></StackPanel></UniformGrid>
    <TextBlock Style="{StaticResource Label}" Text="位置和尺寸（相对画布百分比）"/>
    <UniformGrid Columns="4"><TextBlock Text="X" TextAlignment="Center"/><TextBlock Text="Y" TextAlignment="Center"/><TextBlock Text="宽度" TextAlignment="Center"/><TextBlock Text="高度" TextAlignment="Center"/></UniformGrid>
    <UniformGrid Columns="4"><TextBox x:Name="XBox"/><TextBox x:Name="YBox"/><TextBox x:Name="WBox"/><TextBox x:Name="HBox"/></UniformGrid>
    <Button x:Name="ApplyBtn" Content="应用属性并刷新预览" Background="#E8F0FF" Margin="0,7,0,0"/>
   </StackPanel></ScrollViewer></Border>
  </Grid>
 </DockPanel>
 <Grid x:Name="StartPage" Background="#F4F6F9">
  <Grid.ColumnDefinitions><ColumnDefinition Width="300"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
  <Border Grid.Column="0" Background="#25324A"><StackPanel Margin="34" VerticalAlignment="Center">
   <TextBlock Text="BMAP" Foreground="White" FontSize="36" FontWeight="Bold"/>
   <TextBlock Text="文本框样式编辑器" Foreground="#DCE7FF" FontSize="20" Margin="0,8,0,0" TextWrapping="Wrap"/>
   <TextBlock Text="设计、预览并同步 ThoughtCanvas 文本框样式" Foreground="#9FB2D6" FontSize="13" Margin="0,16,0,0" TextWrapping="Wrap"/>
  </StackPanel></Border>
  <Grid Grid.Column="1"><StackPanel Width="620" HorizontalAlignment="Center" VerticalAlignment="Center">
   <DockPanel Margin="0,0,0,22"><TextBlock Text="开始" FontSize="30" FontWeight="Bold"/><Button x:Name="StartLanguageBtn" Content="EN" HorizontalAlignment="Right"/></DockPanel>
   <UniformGrid Columns="3">
    <Button x:Name="StartNewBtn" Height="130" Margin="7" Content="新建设计" FontSize="18"/>
    <Button x:Name="StartOpenBtn" Height="130" Margin="7" Content="打开样式" FontSize="18"/>
    <Button x:Name="StartConnectBtn" Height="130" Margin="7" Content="连接主程序" FontSize="18"/>
   </UniformGrid>
   <TextBlock Text="可以不连接主程序独立设计和预览；连接后可直接同步样式。" Foreground="#6E7789" TextAlignment="Center" Margin="0,22,0,0"/>
  </StackPanel></Grid>
 </Grid>
 </Grid>
</Window>
